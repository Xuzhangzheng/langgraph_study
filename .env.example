LLM_PROVIDER=openai

# OpenAI 配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

# 火山引擎（方舟）配置，使用时把 LLM_PROVIDER 改为 volcengine
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 一般填写你在方舟控制台创建的 endpoint_id（例如 ep-xxxxxxxx）
VOLCENGINE_MODEL=your_volcengine_endpoint_id_here

# 火山引擎（方舟）官方 SDK 配置，使用时把 LLM_PROVIDER 改为 ark
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 可直接使用官方模型名，例如 doubao-seed-2-0-lite-260215
ARK_MODEL=doubao-seed-2-0-lite-260215
